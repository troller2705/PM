{
  "name": "Permission",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "code": {
      "type": "string",
      "description": "Permission code (e.g., project.create, task.delete)"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "project",
        "task",
        "budget",
        "user",
        "admin",
        "git",
        "report"
      ],
      "default": "project"
    },
    "is_system": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "name",
    "code"
  ]
}