{
  "name": "WorkflowRule",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "trigger_event": {
      "type": "string",
      "enum": [
        "status_change",
        "assignee_change",
        "due_date_approaching",
        "task_created"
      ],
      "default": "status_change"
    },
    "trigger_condition": {
      "type": "object",
      "description": "Conditions for the trigger, e.g. {from_status: 'in_progress', to_status: 'review'}",
      "properties": {
        "from_status": {
          "type": "string"
        },
        "to_status": {
          "type": "string"
        },
        "task_type": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        }
      }
    },
    "action_type": {
      "type": "string",
      "enum": [
        "assign_to_user",
        "change_status",
        "require_approval"
      ],
      "default": "assign_to_user"
    },
    "action_config": {
      "type": "object",
      "description": "Action configuration, e.g. {user_id: '...', status: 'review'}",
      "properties": {
        "user_id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "approver_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_message": {
          "type": "string"
        }
      }
    },
    "execution_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "trigger_event",
    "action_type"
  ]
}