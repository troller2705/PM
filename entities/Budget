{
  "name": "Budget",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "fiscal_year": {
      "type": "number"
    },
    "project_id": {
      "type": "string"
    },
    "department_id": {
      "type": "string"
    },
    "total_amount": {
      "type": "number"
    },
    "allocated_amount": {
      "type": "number",
      "default": 0
    },
    "spent_amount": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending_approval",
        "approved",
        "active",
        "frozen",
        "closed"
      ],
      "default": "draft"
    },
    "approved_by": {
      "type": "string"
    },
    "approved_date": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "fiscal_year",
    "total_amount"
  ]
}