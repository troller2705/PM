{
  "name": "Milestone",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "completed",
        "missed"
      ],
      "default": "pending"
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "name",
    "project_id"
  ]
}