{
  "name": "ApprovalRequest",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string"
    },
    "milestone_id": {
      "type": "string"
    },
    "rule_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "requester_id": {
      "type": "string"
    },
    "approver_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending"
    },
    "approved_by": {
      "type": "string"
    },
    "rejected_by": {
      "type": "string"
    },
    "resolution_note": {
      "type": "string"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "title",
    "status"
  ]
}